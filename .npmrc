# Skip all optional dependencies at install time.
# Heavy components (@xenova/transformers, ethers) are installed
# on-demand by rdk commands when the user first needs them.
optional=false

# Faster installs — skip package scripts during workspace install
# (native binaries like better-sqlite3 use prebuilds, no compile needed)
ignore-scripts=false

# The desktop app (apps/desktop) depends on the Electron toolchain
# (@electron/rebuild, electron-builder), which pulls @electron/node-gyp —
# Electron's git-forked node-gyp. That's a legitimate, ubiquitous Electron
# dependency, so exotic (git) subdeps are permitted for this workspace.
block-exotic-subdeps=false
