{
  "name": "@retrodeck/adapter-obsidian",
  "version": "1.0.0",
  "description": "RDK vault adapter for Obsidian — wikilinks, frontmatter, graph-aware indexing",
  "main": "./dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js --external:better-sqlite3 --external:chokidar --external:@xenova/transformers && chmod +x dist/index.js",
    "prepublishOnly": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js --external:better-sqlite3 --external:chokidar --external:@xenova/transformers",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "optionalDependencies": {
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@rdk/core": "workspace:*",
    "@types/node": "^22.15.21",
    "esbuild": "^0.28.0",
    "glob": "^11.0.2",
    "gray-matter": "^4.0.3",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist/",
    "package.json"
  ]
}
